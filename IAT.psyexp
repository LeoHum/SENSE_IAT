        <Param val="cor_resp = 1;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="cor_resp = 1" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if keyboard_resp.keys:&amp;#10;    if keyboard_resp.keys[0] != CorrAns and len(keyboard_resp.keys) &gt;  0 : #affiche le message &quot;erreur&quot; si la première touche appuyée n'est pas la bonne&amp;#10;        cor_resp = 0&amp;#10;    else:&amp;#10;        cor_resp = 1 #active la condition pour afficher le composant error_msg&amp;#10;&amp;#10;&amp;#10;if keyboard_resp.keys:&amp;#10;    if len(keyboard_resp.keys) &gt; 0 and keyboard_resp.keys[-1] == CorrAns: #vérifie si la touche est correcte et passe à l'essai suivant le cas échéant&amp;#10;        keyboard_resp.corr = True&amp;#10;        continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if (keyboard_resp.keys) {&amp;#10;    if (((keyboard_resp.keys[0] !== CorrAns) &amp;&amp; (keyboard_resp.keys.length &gt; 0))) {&amp;#10;        cor_resp = 0;&amp;#10;    } else {&amp;#10;        cor_resp = 1;&amp;#10;    }&amp;#10;}&amp;#10;if (keyboard_resp.keys) {&amp;#10;    if (((keyboard_resp.keys.length &gt; 0) &amp;&amp; (keyboard_resp.keys.slice((- 1))[0] === CorrAns))) {&amp;#10;        keyboard_resp.corr = true;&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
