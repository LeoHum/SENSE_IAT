      </CodeComponent>
      <CodeComponent name="compute_score" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="rt_block3 = []&amp;#10;err_block3 = 0 &amp;#10;rt_block5 = []&amp;#10;err_block5 = 0&amp;#10;fast_responses = 0&amp;#10;slow_responses = 0&amp;#10;total_responses = 0&amp;#10;num_errors = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="rt_block3 = [];&amp;#10;err_block3 = 0;&amp;#10;rt_block5 = [];&amp;#10;err_block5 = 0;&amp;#10;fast_responses = 0;&amp;#10;slow_responses = 0;&amp;#10;total_responses = 0;&amp;#10;num_errors = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if ((conds_file === &quot;cong_test.xlsx&quot;)) {&amp;#10;    if ((((typeof keyboard_resp.rt.slice((- 1))[0]) === &quot;number&quot;) || (keyboard_resp.rt.slice((- 1))[0] instanceof Number))) {&amp;#10;        rt_block3.push(keyboard_resp.rt.slice((- 1))[0]);&amp;#10;        if ((keyboard_resp.rt.slice((- 1))[0] &lt; 0.3)) {&amp;#10;            fast_responses = (fast_responses + 1);&amp;#10;        }&amp;#10;        if ((keyboard_resp.keys[0] !== CorrAns)) {&amp;#10;            err_block3 = (err_block3 + 1);&amp;#10;        }&amp;#10;    }&amp;#10;} else {&amp;#10;    if ((conds_file === &quot;incong_test.xlsx&quot;)) {&amp;#10;        if ((((typeof keyboard_resp.rt.slice((- 1))[0]) === &quot;number&quot;) || (keyboard_resp.rt.slice((- 1))[0] instanceof Number))) {&amp;#10;            rt_block5.push(keyboard_resp.rt.slice((- 1))[0]);&amp;#10;            if ((keyboard_resp.rt.slice((- 1))[0] &lt; 0.3)) {&amp;#10;                fast_responses = (fast_responses + 1);&amp;#10;            }&amp;#10;            if ((keyboard_resp.keys[0] !== CorrAns)) {&amp;#10;                err_block5 = (err_block5 + 1);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;if (((keyboard_resp.keys[0] !== CorrAns) &amp;&amp; keyboard_resp.keys)) {&amp;#10;    num_errors = (num_errors + 1);&amp;#10;}&amp;#10;if (((keyboard_resp.rt.slice((- 1))[0] &gt; 3) &amp;&amp; keyboard_resp.keys)) {&amp;#10;    slow_responses = (slow_responses + 1);&amp;#10;}&amp;#10;total_responses = (total_responses + 1);&amp;#10;keyboard_resp.keys = [];&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if conds_file == &quot;cong_test.xlsx&quot;: #ajout du temps de réponse pour le bloc congruent&amp;#10;    if isinstance(keyboard_resp.rt[-1], float):&amp;#10;        rt_block3.append(keyboard_resp.rt[-1])&amp;#10;        if keyboard_resp.rt[-1] &lt; 0.3: #vérification si la réponse est trop rapide&amp;#10;            fast_responses = fast_responses + 1&amp;#10;        if keyboard_resp.keys[0] != CorrAns: #calcul du nb d'erreurs du bloc congruent&amp;#10;            err_block3 = err_block3 + 1&amp;#10;elif conds_file == &quot;incong_test.xlsx&quot;: #ajout du temps de réponse pour le bloc incongruent&amp;#10;    if isinstance(keyboard_resp.rt[-1], float):&amp;#10;        rt_block5.append(keyboard_resp.rt[-1]) #vérification si la réponse est trop rapide&amp;#10;        if keyboard_resp.rt[-1] &lt; 0.3:&amp;#10;            fast_responses = fast_responses + 1&amp;#10;        if keyboard_resp.keys[0] != CorrAns: #calcul du nb d'erreurs du bloc incongruent&amp;#10;            err_block5 = err_block5 + 1&amp;#10;&amp;#10;if keyboard_resp.keys[0] != CorrAns and keyboard_resp.keys: #store le nb total d'erreurs&amp;#10;    num_errors = num_errors+ 1&amp;#10;    &amp;#10;if keyboard_resp.rt[-1] &gt; 3 and keyboard_resp.keys: #verification si la réponse est trop lente&amp;#10;    slow_responses = slow_responses + 1 &amp;#10;&amp;#10;total_responses = total_responses + 1 #nb total d'essais&amp;#10;&amp;#10;keyboard_resp.keys = []" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="compute_score" valType="code" updates="None" name="name"/>
      </CodeComponent>
